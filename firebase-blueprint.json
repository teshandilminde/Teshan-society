{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing basic info",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "timestamp" },
        "lastLogin": { "type": "timestamp" }
      },
      "required": ["lastLogin"]
    },
    "Slide": {
      "title": "Slide",
      "description": "A slide with code content",
      "type": "object",
      "properties": {
        "order": { "type": "number" },
        "type": { "type": "string" },
        "name": { "type": "string" },
        "privacy": { "type": "string" },
        "commentsEnabled": { "type": "boolean" },
        "commentsCount": { "type": "number" },
        "code": { "type": "string" }
      },
      "required": ["order", "type", "name", "privacy"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "slides/{slideId}": {
      "schema": { "$ref": "#/entities/Slide" },
      "description": "Stores slides."
    }
  }
}
